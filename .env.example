NODE_ENV=development
PORT=3000
TRUST_PROXY=0

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=bpn_booking
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_TIMEZONE=+08:00

# Alternatif untuk database Clever Cloud.
# Jika variabel MYSQL_ADDON_* diisi, aplikasi akan memakainya lebih dulu
# daripada DB_HOST/DB_USER/DB_PASSWORD/DB_NAME.
MYSQL_ADDON_HOST=
MYSQL_ADDON_DB=
MYSQL_ADDON_USER=
MYSQL_ADDON_PORT=3306
MYSQL_ADDON_PASSWORD=
MYSQL_ADDON_URI=

# Alternatif untuk Railway MySQL.
MYSQL_URL=
MYSQLHOST=
MYSQLPORT=3306
MYSQLUSER=
MYSQLPASSWORD=
MYSQLDATABASE=

JWT_SECRET=ganti_dengan_secret_minimal_32_karakter
JWT_EXPIRES_IN=1d

# Pisahkan dengan koma jika lebih dari satu domain.
# Kosongkan saat development lokal agar semua origin lokal tetap bisa dipakai.
CORS_ORIGINS=

# Rate limit login/register
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10

# Upload hasil pemeriksaan: default 3 MB, hanya JPG/PNG/WEBP.
UPLOAD_MAX_BYTES=3145728

# Gmail SMTP
# Gunakan Google App Password 16 karakter, bukan password login Gmail biasa.
# App Password biasanya terlihat seperti "abcd efgh ijkl mnop"; boleh ditulis dengan spasi atau tanpa spasi.
EMAIL_USER=sistembpnlutim@gmail.com
EMAIL_PASS=app_password_16_karakter
EMAIL_SERVICE=gmail

# Opsional: alamat tujuan untuk npm run test:email
EMAIL_TEST_TO=email_tujuan_untuk_tes@example.com

# Opsional: aktifkan log sukses pengiriman email
EMAIL_DEBUG=false

# Opsional: jumlah email background yang boleh dikirim bersamaan
EMAIL_QUEUE_CONCURRENCY=2

# Opsional: log API jika lebih lambat dari nilai ini (ms)
SLOW_REQUEST_MS=5000
